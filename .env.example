# AI-Crypto Nexus Configuration
NEXUS_ENV=development
NEXUS_LOG_LEVEL=INFO

# Blockchain RPCs
NEXUS_ETHEREUM_RPC=https://eth.llamarpc.com
NEXUS_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
NEXUS_BASE_RPC=https://mainnet.base.org

# AI/LLM
NEXUS_OPENAI_API_KEY=sk-...
NEXUS_ANTHROPIC_API_KEY=sk-ant-...
NEXUS_LLM_MODEL=gpt-4

# Data Sources
NEXUS_ETHERSCAN_API_KEY=...
NEXUS_COINGECKO_API_KEY=...

# Redis
NEXUS_REDIS_URL=redis://localhost:6379/0
